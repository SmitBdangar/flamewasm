;; Branch / control flow spec fixture
(module
  (func (export "br_if") (param i32) (result i32)
    (block (result i32)
      (i32.const 1)
      (br_if 0 (local.get 0))
      (drop)
      (i32.const 0)
    )
  )
  (func (export "select") (param i32 i32 i32) (result i32)
    (select (local.get 0) (local.get 1) (local.get 2))
  )
  (func (export "loop_sum") (param $n i32) (result i32)
    (local $i i32)
    (local $s i32)
    (loop $lp
      (local.set $s (i32.add (local.get $s) (local.get $i)))
      (local.set $i (i32.add (local.get $i) (i32.const 1)))
      (br_if $lp (i32.lt_s (local.get $i) (local.get $n)))
    )
    (local.get $s)
  )
)

(assert_return (invoke "br_if" (i32.const 1)) (i32.const 1))
(assert_return (invoke "br_if" (i32.const 0)) (i32.const 0))
(assert_return (invoke "select" (i32.const 10) (i32.const 20) (i32.const 1)) (i32.const 10))
(assert_return (invoke "select" (i32.const 10) (i32.const 20) (i32.const 0)) (i32.const 20))
(assert_return (invoke "loop_sum" (i32.const 5)) (i32.const 10))
